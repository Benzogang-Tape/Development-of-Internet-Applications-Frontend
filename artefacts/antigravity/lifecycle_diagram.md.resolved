## Схема жизненного цикла [MaterialsPage](file:///Users/l.poljakov/Documents/BMSTU/Development%20of%20internet%20applications/Development-of-Internet-Applications-Frontend/src/pages/MaterialsPage.tsx#9-83)

```mermaid
flowchart TD
    subgraph mounting["⬇️ MOUNTING — первый рендер"]
        direction TB
        M1["🔵 useState × 3
        materials = []
        loading = true
        searchQuery = ''"]
        M2["🟢 render — первый вызов JSX
        loading === true → Spinner"]
        M3["🟡 useEffect([], mount)
        → loadMaterials()"]
        M4["⚡ fetch GET /api/roofing_materials
        → setLoading(true)
        → setMaterials(data)
        → setLoading(false)"]

        M1 --> M2
        M2 --> M3
        M3 --> M4
    end

    subgraph update1["🔄 UPDATING — после загрузки данных"]
        direction TB
        U1["setState вызовы:
        setLoading(false)
        setMaterials(data)"]
        U2["🟢 re-render
        loading === false
        materials.length > 0
        → MaterialCard × N"]

        U1 --> U2
    end

    subgraph update2["🔄 UPDATING — пользователь ищет"]
        direction TB
        S1["Ввод в input
        → setSearchQuery('черепица')"]
        S2["🟢 re-render — изменился searchQuery
        (input отображает новый текст)"]
        S3["Нажатие 'Найти' / Enter
        → handleSearchSubmit()
        → e.preventDefault()
        → loadMaterials()"]
        S4["⚡ fetch GET /api/...?roofing_material=черепица
        → setLoading(true) → re-render (Spinner)
        → setMaterials(filtered) → setLoading(false)"]
        S5["🟢 re-render
        → отфильтрованные MaterialCard"]

        S1 --> S2
        S2 --> S3
        S3 --> S4
        S4 --> S5
    end

    subgraph unmount["❌ UNMOUNTING"]
        direction TB
        X1["Пользователь уходит на другую страницу
        React удаляет компонент из DOM
        (cleanup-функции useEffect нет —
        нечего очищать)"]
    end

    mounting --> update1
    update1 --> update2
    update2 --> unmount

    style M1 fill:#e3f2fd,stroke:#1976d2
    style M2 fill:#e8f5e9,stroke:#388e3c
    style M3 fill:#fff9c4,stroke:#f9a825
    style M4 fill:#fff3e0,stroke:#ef6c00
    style U1 fill:#e3f2fd,stroke:#1976d2
    style U2 fill:#e8f5e9,stroke:#388e3c
    style S1 fill:#e3f2fd,stroke:#1976d2
    style S2 fill:#e8f5e9,stroke:#388e3c
    style S3 fill:#fff9c4,stroke:#f9a825
    style S4 fill:#fff3e0,stroke:#ef6c00
    style S5 fill:#e8f5e9,stroke:#388e3c
    style X1 fill:#ffebee,stroke:#c62828
```

